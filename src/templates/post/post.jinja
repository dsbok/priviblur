{% from 'post/components/header.jinja' import create_post_header  %}
{% set has_media = false %}
{% for block in element.content %}
    {% if block.type in ["image", "video", "audio"] %}
        {% set has_media = true %}
    {% endif %}
{% endfor %}
{% for trail_item in element.trail %}
    {% for block in trail_item.content %}
        {% if block.type in ["image", "video", "audio"] %}
            {% set has_media = true %}
        {% endif %}
    {% endfor %}
{% endfor %}
<div class="post {% if not has_media %}text-only{% endif %}" data-post-id="{{element.id}}">
    {%- if post_url is not defined -%} 
        {%- set post_url = element.blog.name|e + "/" + element.id | e -%}
        {%- if element.slug -%}
            {%- set post_url = post_url + "/" + element.slug | e -%}
        {%- endif -%}
    {%- endif -%}

    {{- create_post_header(request, element, use_this_post_url=post_url) -}}
    {% include 'post/components/body.jinja'  %}
    {% include 'post/components/footer.jinja'  %}
</div>
