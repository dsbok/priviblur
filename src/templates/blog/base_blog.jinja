{% extends "base.jinja" %}
{% block head %}
<link rel="preload" href="/assets/css/blog.css?v={{app.ctx.CURRENT_COMMIT}}" as="style">
<link rel="stylesheet" type="text/css" href="/assets/css/blog.css?v={{app.ctx.CURRENT_COMMIT}}">
{% if blog.next %}
    {% if query_args is defined %}
        <link rel="prefetch" href="{{request.path}}{{add_query(query_args | update_query_params("continuation", blog.next.cursor))}}">
    {% else %}
        <link rel="prefetch" href="{{request.path}}?continuation={{blog.next.cursor | urlencode}}">
    {% endif %}
{% endif %}
{%- block child_block_include -%}{%- endblock -%}
{% endblock %}
{% block title -%}
    {%- if blog.blog_info.title -%}
        {{blog.blog_info.title | e}}
    {%- else -%}
        {{blog.blog_info.name | e}}
    {%- endif -%}
{% endblock %}

{% block center %}
    {%- include 'components/blog_header.jinja' -%}

    <div style="display: flex; gap: 10px; margin-bottom: 20px;">
        <form class="blog-search-bar search-bar" method="get" action="/{{blog.blog_info.name}}/search" autocomplete="off" style="flex: 1; margin: 0;">
        {{-search_icon(20, 20)}}
        {%- if blog_search_query is defined -%}
            <input name="q" type="text" value="{{blog_search_query | e}}" placeholder="{{translate(request.ctx.language, "blog_search_placeholder_text")}}"></input>
        {%- else -%}
            <input name="q" type="text" placeholder={{translate(request.ctx.language, "blog_search_placeholder_text")}}></input>
        {%- endif -%}
        </form>

        <select id="media-filter" style="padding: 10px; border-radius: 4px; background: var(--bg-surface-secondary); color: var(--text-primary); border: 1px solid var(--border-color); cursor: pointer;" onchange="applyMediaFilter()">
            <option value="all">All Posts</option>
            <option value="media-only">Media Only (Hide Text Posts)</option>
        </select>
    </div>

    <script>
        function applyMediaFilter() {
            const filter = document.getElementById("media-filter").value;
            const textOnlyPosts = document.querySelectorAll(".post.text-only");
            
            if (filter === "media-only") {
                textOnlyPosts.forEach(post => post.style.display = "none");
            } else {
                textOnlyPosts.forEach(post => post.style.display = "block");
            }
            
            // Save preference to localStorage
            localStorage.setItem("mediaFilterPreference", filter);
        }

        // Apply on load
        document.addEventListener("DOMContentLoaded", () => {
            const savedFilter = localStorage.getItem("mediaFilterPreference");
            if (savedFilter) {
                document.getElementById("media-filter").value = savedFilter;
                applyMediaFilter();
            }
        });
    </script>
    
    {%- block blog_contents %}
    {%- endblock %}

    {%- if blog.next %}
        <div class="paging">
            {% block paging %}
                <a class="primary next-page button" href="{{request.path}}?continuation={{blog.next.cursor | urlencode}}#m">
                    {{translate(request.ctx.language, "pagination_next_page")}}
                </a>
            {% endblock%}
        </div>
    {% endif %}
{%- endblock %}
