{% extends "timeline.jinja" %}
{% block title %}{{query | e}}{% endblock %}
{% from 'components/icons/expand.jinja' import dropdown_icon  %}
{% block control_bar %}
    <select onchange="window.location.href=this.value">
            {%- if post_filter -%}
                <option value="/search/{{query | encodepathsegment}}/{{post_filter | encodepathsegment}}{{ add_query(query_args | deseq_urlencode) }}" {% if sort_by == "popular"%} selected {% endif %}>{{translate(request.ctx.language, "timeline_search_sort_by_filter_popular")}}</option>
                <option value="/search/{{query | encodepathsegment}}/recent/{{post_filter | encodepathsegment}}{{ add_query(query_args | deseq_urlencode) }}" {% if sort_by == "recent"%} selected {% endif %}>{{translate(request.ctx.language, "timeline_search_sort_by_filter_recent")}}</option>
            {%- else -%}
                <option value="/search/{{query | encodepathsegment}}{{ add_query(query_args | deseq_urlencode) }}" {% if sort_by == "popular"%} selected {% endif %}>{{translate(request.ctx.language, "timeline_search_sort_by_filter_popular")}}</option>
                <option value="/search/{{query | encodepathsegment}}/recent{{ add_query(query_args | deseq_urlencode )}}" {% if sort_by == "recent"%} selected {% endif %}>{{translate(request.ctx.language, "timeline_search_sort_by_filter_recent")}}</option>
            {%- endif -%}
        </select>

    {%- if sort_by == "popular" -%}
        <select onchange="window.location.href=this.value">
                <option value="{{request.path}}{{ add_query(query_args | remove_query_params("t")) }}" {% if time_filter == 0 %} selected {% endif %}>{{translate(request.ctx.language, "timeline_search_filter_by_date_filter_0")}}</option>
                {%- for time in ("365", "180", "30", "7", "1") -%}
                    <option value="{{request.path}}{{ add_query(query_args | update_query_params("t", time)) }}" {% if time_filter == time %} selected {% endif %}>{{translate(request.ctx.language, "timeline_search_filter_by_date_filter_" + time | string)}}</option>
                {%- endfor -%}
            </select>
    {%- endif -%}

    {%- if post_filter is none -%}
        {% set selected_post_filter_label = translate(request.ctx.language, "timeline_search_post_type_filter_none")%}
    {%- else -%}
        {% set selected_post_filter_label = translate(request.ctx.language, "timeline_search_post_type_filter_" + post_filter) %}
    {%- endif -%}

    <select onchange="window.location.href=this.value">
            {%- if sort_by == "recent" -%}
                <option value="/search/{{query | encodepathsegment}}/recent{{ add_query(query_args | deseq_urlencode) }}" {% if post_filter is none %} selected {% endif %}>{{translate(request.ctx.language, "timeline_search_post_type_filter_none")}}</option>
            {%- else -%}
                <option value="/search/{{query | encodepathsegment}}/{{ add_query(query_args | deseq_urlencode) }}" {% if post_filter is none %} selected {% endif %}>{{translate(request.ctx.language, "timeline_search_post_type_filter_none" )}}</option>
            {%- endif -%}

            {%- for post_type in ("text", "photo", "gif", "quote", "link", "chat", "audio", "video", "ask", "poll") -%}
                {%- if sort_by == "recent" -%}
                    <option value="/search/{{query | encodepathsegment}}/recent/{{post_type | encodepathsegment}}{{ add_query(query_args | deseq_urlencode) }}" {% if post_filter == post_type %} selected {% endif %}>{{translate(request.ctx.language, "timeline_search_post_type_filter_" + post_type )}}</option>
                {%- else -%}
                    <option value="/search/{{query | encodepathsegment}}/{{post_type | encodepathsegment}}{{ add_query(query_args | deseq_urlencode) }}" {% if post_filter == post_type%} selected {% endif %}>{{translate(request.ctx.language, "timeline_search_post_type_filter_" + post_type )}}</option>
                {%- endif -%}
            {%- endfor -%}
        </select>
{% endblock %}

{% block paging %}
    <a class="primary next-page button" href="{{request.path}}{{add_query(query_args | update_query_params("continuation", timeline.next.cursor))}}#m">
        {{translate(request.ctx.language, "pagination_next_page")}}
    </a>
{% endblock %}
