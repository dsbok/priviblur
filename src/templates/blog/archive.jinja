{% extends "blog/base_blog.jinja" %}
{% block blog_contents %}
<div class="archive-container" style="background: var(--bg-surface); padding: 20px; border-radius: 8px; margin: 20px 0;">
    <h2>Archive Time Machine</h2>
    <p style="color: var(--text-secondary); margin-bottom: 15px;">Jump back in time to view posts from a specific month and year.</p>
    
    <form method="get" action="/{{blog.blog_info.name}}/archive" class="archive-form" style="display: flex; gap: 10px; margin-bottom: 20px;">
        <select name="month" required style="padding: 10px; border-radius: 4px; background: var(--bg-surface-secondary); color: var(--text-primary); border: 1px solid var(--border-color);">
            <option value="" disabled selected>Select Month</option>
            <option value="1">January</option>
            <option value="2">February</option>
            <option value="3">March</option>
            <option value="4">April</option>
            <option value="5">May</option>
            <option value="6">June</option>
            <option value="7">July</option>
            <option value="8">August</option>
            <option value="9">September</option>
            <option value="10">October</option>
            <option value="11">November</option>
            <option value="12">December</option>
        </select>

        <select name="year" required style="padding: 10px; border-radius: 4px; background: var(--bg-surface-secondary); color: var(--text-primary); border: 1px solid var(--border-color);">
            <option value="" disabled selected>Select Year</option>
            {% for y in range(2007, 2027) | reverse %}
                <option value="{{ y }}">{{ y }}</option>
            {% endfor %}
        </select>

        <button type="submit" class="button primary" style="padding: 10px 20px;">Jump to Time</button>
    </form>
</div>

<hr style="border: 0; border-top: 1px solid var(--border-color); margin: 20px 0;">

<div class="post-timeline">
    {% for element in blog.elements %}
        {% include "components/post.jinja" %}
    {% endfor %}
</div>
{% endblock %}
