{% extends "timeline.jinja" %}
{% from 'components/icons/expand.jinja' import dropdown_icon  %}
{% block title %}{{tag | e}}{% endblock %}
{% block control_bar %}
    <select onchange="window.location.href=this.value">
            <option value="/tagged/{{tag | encodepathsegment}}{{ add_query(query_args | update_query_params("sort", "top")) }}" {% if sort_by == "top"%} selected {% endif %}>{{translate(request.ctx.language, "timeline_tagged_sort_by_filter_top")}}</option>
            <option value="/tagged/{{tag | encodepathsegment}}{{ add_query(query_args | update_query_params("sort", "recent")) }}" {% if sort_by == "recent"%} selected {% endif %}>{{translate(request.ctx.language, "timeline_tagged_sort_by_filter_recent")}}</option>
        </select>
{% endblock %}
