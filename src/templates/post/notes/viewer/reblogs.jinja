{% extends "post/notes/viewer/template.jinja"%}
{% from 'post/components/header.jinja' import create_post_header  %}
{% from 'components/icons/expand.jinja' import dropdown_icon  %}

{% block control_bar %}
    <select onchange="window.location.href=this.value">
            {% if reblog_filter is none  %}
                {% set reblog_filter = "reblogs_with_comments" %}
            {% endif %}
            <option value="/{{post_url}}?note_viewer=reblogs" {% if reblog_filter == "reblogs_with_comments"%} selected {% endif %}>{{translate(request.ctx.language, "post_note_viewer_view_reblogs_filter_reblogs_with_comments")|e}}</option>
            <option value="/{{post_url}}?note_viewer=reblogs&reblog_filter=reblogs_with_content_comments" {% if reblog_filter == "reblogs_with_content_comments"%} selected {% endif %}>{{translate(request.ctx.language, "post_note_viewer_view_reblogs_filter_reblogs_with_content_comments")|e}}</option>
            <option value="/{{post_url}}?note_viewer=reblogs&reblog_filter=reblogs_only" {% if reblog_filter == "reblogs_only"%} selected {% endif %}> {{translate(request.ctx.language, "post_note_viewer_view_reblogs_filter_reblogs_only")|e}}</option>
        </select>
{% endblock %}

{% block notes %}
    {%- for note in notes.notes -%}
        {%- include "post/notes/note/reblog.jinja" -%}
        <hr>
    {%- endfor -%}
{% endblock %}

{% block paging %}
    {% if notes.before_timestamp %}
            <a class="secondary next-page button" href="/{{post_url | e}}?{{request.args | update_query_params("before_timestamp", notes.before_timestamp)}}">{{translate(request.ctx.language, "pagination_next_page")}}</a>
    {% endif %}
{% endblock %}
